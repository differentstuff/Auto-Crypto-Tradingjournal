# exchange.yaml.template -- Copy to exchange.yaml and fill in your API keys.
# NEVER commit exchange.yaml with real keys. It is listed in .gitignore.
#
# Merge order: default.yaml < strategy.yaml < exchange.yaml
# The daemon strips this file's contents from the config before passing
# it to the substrate. Secrets never touch the substrate object.

exchange:
  # Trading exchange configuration
  bitget:
    api_key: "YOUR_BITGET_API_KEY"
    secret_key: "YOUR_BITGET_SECRET_KEY"
    passphrase: "YOUR_BITGET_PASSPHRASE"
    sandbox: false

  binance:
    api_key: "YOUR_BINANCE_API_KEY"
    secret_key: "YOUR_BINANCE_SECRET_KEY"
    sandbox: false

  bybit:
    api_key: "YOUR_BYBIT_API_KEY"
    secret_key: "YOUR_BYBIT_SECRET_KEY"
    sandbox: false

# LLM API keys (KeyManager)
# Each provider can have multiple keys. KeyManager rotates automatically:
#   429/529 (overload)    -> switch to next healthy key, cooldown 30s
#   500/502/503 (server)  -> switch to next key, cooldown 10s
#   401/403 (auth error)  -> disable key permanently, log alert
#
# Provider names must match llm.routing.<role>.provider in default.yaml
# or your strategy YAML.
#
# Supported providers:
#   anthropic   -- Claude models (Haiku, Sonnet, Opus)
#   google      -- Gemini models
#   openrouter  -- 200+ models via single API (OpenAI-compatible)
#                  Free-tier models available: deepseek, llama, qwen, etc.
#                  Get key at: https://openrouter.ai/keys
llm_keys:
  anthropic:
    - key: "sk-ant-api03-YOUR-KEY-1"
      label: "anthropic-key-1"
    # Add a second key for higher throughput / failover:
    # - key: "sk-ant-api03-YOUR-KEY-2"
    #   label: "anthropic-key-2"

  google:
    - key: "AIza-YOUR-KEY-1"
      label: "gemini-key-1"
    # - key: "AIza-YOUR-KEY-2"
    #   label: "gemini-key-2"

  openrouter:
    - key: "sk-or-v1-YOUR-KEY-1"
      label: "openrouter-key-1"
    # Add a second key for higher throughput / failover:
    # - key: "sk-or-v1-YOUR-KEY-2"
    #   label: "openrouter-key-2"
    #
    # Free-tier model examples (set in llm.routing in default.yaml or strategy YAML):
    #   deepseek/deepseek-v4-0324:free       -- fast, good for pre_filter
    #   meta-llama/llama-3.3-70b-instruct:free -- good for rulebook formatting
    #   nvidia/llama-3.1-nemotron-70b-instruct:free
    #   qwen/qwen3-235b-a22b:free

# Telegram (optional, for one-way log push)
# Enable with: modules.telegram_logs: true in your strategy YAML
telegram:
  bot_token: "YOUR_TELEGRAM_BOT_TOKEN"
  chat_id: "YOUR_TELEGRAM_CHAT_ID"
  enabled: false

# Database path override (default: trading_journal.db in project root)
# Useful for pointing multiple strategies at the same shared database.
database:
  path: "trading_journal.db"

# ── Exchange API keys ──────────────────────────────────────────────────────────
# Used by core/exchange.py for authenticated endpoints (trading, balance).
# For paper mode, only the data source (Binance public) is needed — no keys.
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
BLOFIN_API_KEY=
BLOFIN_SECRET_KEY=
BLOFIN_PASSPHRASE=

# ── LLM API keys (legacy, used by v1 root files only) ─────────────────────────
# v2 reads LLM keys from config/exchange.yaml under llm_keys:
#   llm_keys:
#     openrouter:
#       - key: "sk-or-v1-..."
#         label: "openrouter-key-1"
# These env vars are kept for backward compat only.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROK_API_KEY=
GROK_MODEL=grok-3-fast

# ── Optional data source keys ─────────────────────────────────────────────────
NANSEN_API_KEY=
FRED_API_KEY=
COINALYZE_API_KEY=
FINNHUB_API_KEY=

# ── Telegram (optional, for one-way log push) ─────────────────────────────────
# Enable with: modules.telegram_logs: true in your strategy YAML
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=logs/auto-trader.log

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=trading_journal.db

# ── Legacy v1 settings (not used by v2 daemon) ────────────────────────────────
APP_URL=http://localhost:8082
PORT=8082

# ── Exchange API keys ──────────────────────────────────────────────────────────
# Used by core/exchange.py for authenticated endpoints (trading, balance).
# Paper mode needs NO exchange keys — OHLCV data comes from public endpoints.
# Only set these when switching to live trading.
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=    # Custom phrase you set at key creation in Bitget web UI.
                       # NOT your account password. Leave empty for paper mode.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BYBIT_API_KEY=
BYBIT_SECRET_KEY=
BLOFIN_API_KEY=
BLOFIN_SECRET_KEY=
BLOFIN_PASSPHRASE=

# ── LLM API keys ────────────────────────────────────────────────────────────────
# The v2 daemon reads ALL LLM keys from .env (not from YAML).
# Provider mapping:
#   ANTHROPIC_API_KEY_1  -> llm.routing roles using provider "anthropic"
#   GEMINI_API_KEY_1     -> llm.routing roles using provider "google"
#   OPENROUTER_API_KEY_1 -> llm.routing roles using provider "openrouter"
#   GROK_API_KEY_1       -> llm.routing roles using provider "grok"
#
# Multiple keys per provider are supported via numbered vars (_1, _2, _3, etc.).
# KeyManager rotates through available keys on rate-limit errors (429/529).
# Fallback keys can be from a different provider (cross-provider fallback).
#
# Free-tier models available on OpenRouter (no cost):
#   deepseek/deepseek-v4-0324:free, meta-llama/llama-3.3-70b-instruct:free
# Get key at: https://openrouter.ai/keys
ANTHROPIC_API_KEY_1=
GEMINI_API_KEY_1=
OPENROUTER_API_KEY_1=
GROK_API_KEY_1=
# Fallback keys (optional — used when primary key hits rate limit)
OPENROUTER_API_KEY_2=
ANTHROPIC_API_KEY_2=

# ── LLM Provider Endpoints ──────────────────────────────────────────────────────
# Base URLs for LLM providers. Override only if using custom proxies.
# Leave empty to use the provider's default endpoint.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_BASE_URL=
GEMINI_BASE_URL=

# ── Optional data source keys ─────────────────────────────────────────────────
NANSEN_API_KEY=
FRED_API_KEY=
COINALYZE_API_KEY=
FINNHUB_API_KEY=

# ── Telegram (optional, for one-way log push) ─────────────────────────────────
# Enable with: modules.telegram_logs: true in your strategy YAML
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=logs/auto-trader.log

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=trading_journal.db
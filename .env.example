# Copy this file to .env and fill in your values.
# The app reads these via os.environ — never commit .env to git.

BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here

# ── Blofin (optional — leave blank to disable Blofin sync) ───────────────────
BLOFIN_API_KEY=your_blofin_api_key_here
BLOFIN_SECRET_KEY=your_blofin_secret_key_here
BLOFIN_PASSPHRASE=your_blofin_passphrase_here

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — defaults to 8082
PORT=8082

# ── Nansen.ai Smart Money Intelligence (optional) ────────────────────────────
# Free account at nansen.ai — provides smart money netflow per token.
# Used in scanner (finalists only, 1 API call per scan) and call analyzer.
# Signal shown only when 5+ smart money wallets are active.
NANSEN_API_KEY=your_nansen_api_key_here

# ── FRED Macro Data (optional — free key from fred.stlouisfed.org) ───────────
# Provides: Fed Funds Rate, CPI, M2 Money Supply, 10-Year Treasury yield
# Get free API key at: https://fred.stlouisfed.org/docs/api/api_key.html
# The CSV endpoints also work without a key (used as fallback).
FRED_API_KEY=your_fred_api_key_here

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
# Setup: create a bot via @BotFather on Telegram, then get your chat ID
# from @userinfobot or by calling https://api.telegram.org/bot{TOKEN}/getUpdates
#
# The Setup Scanner runs every 30 minutes automatically when these are set.
# If a 6+/10 setup is found, you receive a Telegram alert.

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_numeric_chat_id

# URL shown in Telegram alerts as a deep link back to the journal
APP_URL=http://192.168.1.21:8082

# Optional overrides
# SCANNER_INTERVAL=1800       # seconds between scans (default 1800 = 30 min)
# SCANNER_FIRST_DELAY=300     # seconds before first scan after startup (default 300 = 5 min)
# SCANNER_SCHEDULER=off       # set to 'off' to disable the scheduler entirely

[Unit]
Description=Auto Trader Backtest
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jmh
Group=jmh
WorkingDirectory=/opt/Auto-Crypto-Tradingjournal
ExecStart=/opt/Auto-Crypto-Tradingjournal/venv/bin/python -m core.replay_driver --start 2026-01-01 --strategy paper_v3_learning_test
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/opt/Auto-Crypto-Tradingjournal/.env

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/Auto-Crypto-Tradingjournal /opt/Auto-Crypto-Tradingjournal/logs /opt/Auto-Crypto-Tradingjournal/data /opt/Auto-Crypto-Tradingjournal/backups /opt/Auto-Crypto-Tradingjournal/temp

# Memory protection
MemoryMax=3G

# Logging
StandardOutput=append:/opt/Auto-Crypto-Tradingjournal/logs/backtest-stdout.log
StandardError=append:/opt/Auto-Crypto-Tradingjournal/logs/backtest-stderr.log

[Install]
WantedBy=multi-user.target
